+// ============================================================
+// REPORT QUARTER SELECTOR
+// ============================================================
+// The report quarter selector is independent of the main app quarter.
+// It allows generating reports for any quarter without switching the
+// main transaction view.
+let reportFY = activeFY;
+let reportQ = activeQ;
+
+function updateReportQuarterUI() {
+    var fyLabel = document.getElementById('reportFyLabel');
+    if (fyLabel) fyLabel.textContent = 'FY ' + reportFY;
+    document.querySelectorAll('.report-quarter-tab').forEach(function(tab, i) {
+        tab.classList.toggle('active', i + 1 === reportQ);
+    });
+}
+
+function reportSwitchQuarter(q) {
+    reportQ = q;
+    updateReportQuarterUI();
+    generateReport();
+}
+
+function reportChangeFY(dir) {
+    var parts = reportFY.split('/');
+    var y1 = parseInt(parts[0]) + dir;
+    reportFY = y1 + '/' + (y1 + 1);
+    updateReportQuarterUI();
+    generateReport();
+}
+
+function reportChangeQuarter(dir) {
+    var newQ = reportQ + dir;
+    if (newQ > 4) {
+        newQ = 1;
+        var y1 = parseInt(reportFY.split('/')[0]) + 1;
+        reportFY = y1 + '/' + (y1 + 1);
+    } else if (newQ < 1) {
+        newQ = 4;
+        var y1 = parseInt(reportFY.split('/')[0]) - 1;
+        reportFY = y1 + '/' + (y1 + 1);
+    }
+    reportQ = newQ;
+    updateReportQuarterUI();
+    generateReport();
+}
+
+// Load transactions for a specific FY+Q from localStorage (read-only, does not change app state)
+function getReportQuarterData(fy, q) {
+    var key = getQuarterKey(fy, q);
+    var qm = getQuarterMeta(q);
+    try {
+        var saved = localStorage.getItem(key);
+        if (saved) {
+            var data = JSON.parse(saved);
+            var txns = (data.transactions || []).filter(function(t) {
+                if (t.category === 'Cancelled') return false;
+                var m = getMonth(t.date);
+                if (!m) return true;
+                return qm.months.includes(m);
+            });
+            return { openingBalance: data.openingBalance || 0, transactions: txns };
+        }
+        // Fallback for default Q3 data
+        if (fy === '2025/2026' && q === 3) {
+            var txns = JSON.parse(JSON.stringify(DEFAULT_TRANSACTIONS_Q3)).filter(function(t) {
+                return t.category !== 'Cancelled';
+            });
+            return { openingBalance: 237948.69, transactions: txns };
+        }
+    } catch(e) {}
+    return { openingBalance: 0, transactions: [] };
+}
+
